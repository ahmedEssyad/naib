# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# OpenAI — for embeddings (text-embedding-3-small) and the answering LLM (gpt-4o-mini)
OPENAI_API_KEY=sk-...

# Qdrant Cloud — from https://cloud.qdrant.io > your cluster
QDRANT_URL=https://xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.eu-central.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=...

# Collection name used by ingest / retrieve / eval
QDRANT_COLLECTION=khidmaty_creation_entreprise_fr

# LiveKit Cloud — from https://cloud.livekit.io > your project
# WebSocket URL = wss:// + the "Project URL" shown on the General tab.
# API Key + Secret = create on the Settings > Keys tab (secret only shown once).
LIVEKIT_URL=wss://khidmaty-voice-xxxxxxxx.livekit.cloud
LIVEKIT_API_KEY=API...
LIVEKIT_API_SECRET=...
