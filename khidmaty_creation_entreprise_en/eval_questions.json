{
  "domain": "creation_entreprise",
  "language": "en",
  "description": "Realistic voice queries from Mauritanian citizens/entrepreneurs (English version, often used by foreign investors). Each item has the question, the expected source file(s) for retrieval, and the key facts the answer must contain.",
  "items": [
    {
      "id": "q01",
      "question": "How long does it take to set up a business?",
      "expected_files": ["01_apim_apercu.md", "07_faq.md", "09_portal_summary.md"],
      "must_contain": ["48", "working hours", "complete file"]
    },
    {
      "id": "q02",
      "question": "How much does it cost to create an SARL?",
      "expected_files": ["03_personne_morale.md", "07_faq.md", "01_apim_apercu.md"],
      "must_contain": ["500 MRU", "free", "mobile banking", "registry"]
    },
    {
      "id": "q03",
      "question": "What documents do I need to open a sole proprietorship?",
      "expected_files": ["02_personne_physique.md", "06_documents_universels.md"],
      "must_contain": ["Unified Business Creation Form", "national ID", "property title", "electricity", "bank account"]
    },
    {
      "id": "q04",
      "question": "Can I register my company online?",
      "expected_files": ["07_faq.md", "01_apim_apercu.md", "08_contact_pratique.md"],
      "must_contain": ["Khidmaty", "platform", "online"]
    },
    {
      "id": "q05",
      "question": "I'm a foreigner. Can I open a business in Mauritania?",
      "expected_files": ["07_faq.md", "02_personne_physique.md"],
      "must_contain": ["passport", "residence card", "same rights", "marriage certificate"]
    },
    {
      "id": "q06",
      "question": "What's the difference between an SARL and a sole proprietorship?",
      "expected_files": ["02_personne_physique.md", "03_personne_morale.md", "01_apim_apercu.md"],
      "must_contain": ["legal personality", "liability", "capital", "partner"]
    },
    {
      "id": "q07",
      "question": "What's the minimum capital for an SARL?",
      "expected_files": ["03_personne_morale.md", "07_faq.md"],
      "must_contain": ["10,000 MRU", "release", "certificate"]
    },
    {
      "id": "q08",
      "question": "Where is the APIM One-Stop Shop located?",
      "expected_files": ["08_contact_pratique.md"],
      "must_contain": ["Avenue Mokhtar Ould Daddah", "Tevragh Zeina", "Nouakchott"]
    },
    {
      "id": "q09",
      "question": "What's the APIM phone number?",
      "expected_files": ["08_contact_pratique.md", "09_portal_summary.md"],
      "must_contain": ["+222 38", "info-apim@apim.gov.mr"]
    },
    {
      "id": "q10",
      "question": "Can I pay the fees in cash at the counter?",
      "expected_files": ["07_faq.md", "08_contact_pratique.md"],
      "must_contain": ["mobile banking", "no", "account"]
    },
    {
      "id": "q11",
      "question": "I want to open a branch of my French company in Nouakchott. What's required?",
      "expected_files": ["05_succursale.md"],
      "must_contain": ["parent company", "extract", "Commercial Registry", "articles", "resolution", "director"]
    },
    {
      "id": "q12",
      "question": "What is a GIE?",
      "expected_files": ["04_gie.md", "01_apim_apercu.md"],
      "must_contain": ["Economic Interest Group", "natural or legal persons", "auxiliary", "members"]
    },
    {
      "id": "q13",
      "question": "Can I repatriate my profits abroad?",
      "expected_files": ["07_faq.md"],
      "must_contain": ["repatriate", "taxes", "exchange"]
    },
    {
      "id": "q14",
      "question": "Do I need a physical office?",
      "expected_files": ["07_faq.md", "06_documents_universels.md"],
      "must_contain": ["yes", "address", "mandatory", "property title", "lease"]
    },
    {
      "id": "q15",
      "question": "Can APIM draft my articles of association for me?",
      "expected_files": ["07_faq.md", "03_personne_morale.md"],
      "must_contain": ["no", "firm", "lawyer", "independent"]
    },
    {
      "id": "q16",
      "question": "My business is in transport. Is there anything special?",
      "expected_files": ["06_documents_universels.md", "07_faq.md"],
      "must_contain": ["administrative authorisation", "prior", "ministry", "regulated"]
    },
    {
      "id": "q17",
      "question": "What does the One-Stop Shop actually do for me?",
      "expected_files": ["01_apim_apercu.md", "07_faq.md"],
      "must_contain": ["Commercial Registry", "Tax", "Social Security", "CNSS", "DGI"]
    },
    {
      "id": "q18",
      "question": "What laws govern business creation?",
      "expected_files": ["09_portal_summary.md", "02_personne_physique.md", "03_personne_morale.md"],
      "must_contain": ["Decree no. 2022-169", "Law no. 2021-005", "Commercial Code", "General Tax Code"]
    },
    {
      "id": "q19",
      "question": "What documents do I need for an SARL with 50,000 MRU capital?",
      "expected_files": ["03_personne_morale.md"],
      "must_contain": ["articles", "certificate of deposit", "capital", "10,000 MRU", "release"]
    },
    {
      "id": "q20",
      "question": "I want to create a GIE between three companies. What documents?",
      "expected_files": ["04_gie.md"],
      "must_contain": ["group agreement", "Commercial Registry extracts", "articles of the members", "certified list", "managers"]
    }
  ]
}
